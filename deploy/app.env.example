# Production env for systemd: copy to /etc/eve-core/app.env (chmod 600).
# Same keys as repo root .env.example — Next.js reads these from the process environment.

OPENAI_API_KEY=
ELEVENLABS_API_KEY=
ELEVENLABS_VOICE_ID=
MORALIS_API_KEY=
NEXT_PUBLIC_RPC_URL=

# /eve stream (runtime — restart eve-core after edit; no rebuild if using EVE_*)
# EVE_DEFAULT_ROOM=https://pump.fun/coin/...   # or mint
# EVE_AUTO_CONNECT=1
# EVE_STREAM_USERNAME=EVE
# EVE_STREAM_NAME=My Token
# EVE_STREAM_TICKER=PUMP
# EVE_KIOSK=1
# Optional build-time fallbacks (require npm run build if used instead):
# NEXT_PUBLIC_EVE_DEFAULT_ROOM=
# NEXT_PUBLIC_EVE_AUTO_CONNECT=1
# NEXT_PUBLIC_EVE_STREAM_USERNAME=
# NEXT_PUBLIC_EVE_STREAM_NAME=
# NEXT_PUBLIC_EVE_STREAM_TICKER=
# NEXT_PUBLIC_EVE_KIOSK=1

# If `next build` hits native SWC bus errors on this VPS, uncomment:
# NEXT_TEST_WASM=1

# --- Ops dashboard (/ops) — Privy + Solana allowlist ---
# Same Privy app as social-tts: https://dashboard.privy.io
# NEXT_PUBLIC_PRIVY_APP_ID=
# PRIVY_APP_SECRET=
# PEM or JWKS string from Privy dashboard (API → Verification key)
# PRIVY_JWT_VERIFICATION_KEY=
# Solana wallet addresses (base58), comma/space separated — must match a linked wallet on the Privy user
# OPS_ADMIN_SOLANA_WALLETS=
# Legacy name (also Solana base58): OPS_ADMIN_WALLETS=
# OPS_SESSION_SECRET=

# Optional: PostgreSQL — enables durable eve_ops_streams + existing agent_turns memory tables
# DATABASE_URL=postgresql://user:pass@localhost:5432/eve

# Eve Trend Analyst default mint (example — align EVE_DEFAULT_ROOM with this on VPS)
# EVE_DEFAULT_ROOM=4mVbX7EZonRcEfiyFbbw2ByrYc7xAkUMp3NKWhDwpump
