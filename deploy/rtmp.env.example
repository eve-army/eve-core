# Copy to /etc/eve-core/rtmp.env (chmod 600). Do not commit real values.
#
# LiveKit / pump.fun RTMP ingress — confirm the full URL in your dashboard.
# Common patterns:
#   RTMP_URL=rtmps://HOST/live/STREAM_KEY
#   RTMP_URL=rtmps://pump-prod-tg2x8veh.rtmp.livekit.cloud/x/STREAM_KEY
#
# Option A — single full URL (recommended once verified):
RTMP_URL=

# Option B — split (script joins with a single slash):
# RTMP_BASE=rtmps://pump-prod-tg2x8veh.rtmp.livekit.cloud/x
# RTMP_STREAM_KEY=

# ffmpeg input: lavfi (test pattern + tone) | loop (video file) | black (silent black frame)
INPUT_MODE=lavfi

# loop mode only — path on VPS to MP4/WebM to loop
# INPUT_FILE=/opt/eve-core/media/promo.mp4

# Video tuning (optional)
# VIDEO_SIZE=854x480
# VIDEO_FPS=24
# VIDEO_BITRATE=2000k
# VIDEO_MAXRATE=2500k
# AUDIO_BITRATE=128k

# --- eve-browser-rtmp.service (Chromium capture of /eve) ---
# Mutually exclusive with eve-livekit-rtmp on the same RTMP_URL.
# EVE_INTERNAL_URL=http://127.0.0.1:3000/eve
# DISPLAY_NUM=99
# VIDEO_SIZE=1280x720
# VIDEO_FPS=24
