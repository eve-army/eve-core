# =============================================================================
# eve-core — environment variables (copy to `.env.local` and fill in values)
# Next.js loads: .env, .env.local, .env.development.local, etc.
# =============================================================================

# -----------------------------------------------------------------------------
# Required for AI assistant + default voice (ElevenLabs)
# Used by: src/app/api/agent/respond/route.ts
# -----------------------------------------------------------------------------
# Qwen (Ollama) — chat completions via self-hosted server
# Defaults to https://server.songjam.space if unset
# QWEN_BASE_URL=https://server.songjam.space

# ElevenLabs — TTS when voice is set to "elevenlabs_default" in the UI
# Get a key: https://elevenlabs.io/ → Profile → API Key
ELEVENLABS_API_KEY=

# Voice ID for default ElevenLabs TTS (optional). Find under Voices in the ElevenLabs UI.
# Default in code if unset: Rachel (PB6BdkFkZLbI39GHdnbQ)
ELEVENLABS_VOICE_ID=

# XTTS — local Coqui TTS v2 server (free, runs on your machine / VPS)
# Start with: bash xtts-server/start.sh
# Leave unset to disable XTTS voices in the dropdown.
XTTS_BASE_URL=http://localhost:8020

# -----------------------------------------------------------------------------
# Live trends (polar radar + agent context) — proxied by GET /api/live-trends
# -----------------------------------------------------------------------------
# Upstream JSON URL (defaults to Songjam worker if unset)
# LIVE_TRENDS_URL=

# Server: cache upstream for N seconds (omit or 0 = fetch every request; avoids hammering worker)
# LIVE_TRENDS_CACHE_SEC=0

# Client poll interval (ms). Browser uses NEXT_PUBLIC_* (min 5000 in code). Default 15000 if unset.
# NEXT_PUBLIC_LIVE_TRENDS_POLL_MS=15000

# DevTools console: `[live-trends poll] { clientIntervalMs, fetchedAt, count }` each poll after the first.

# Votes: crown winner at this count (!vote / !pick in chat)
# NEXT_PUBLIC_EVE_VOTE_GOAL=15

# Autodeployment agent (Pump.fun) — same host as eve-core recommended
# Agent repo: eve-devs/services/deploy-agent. INTERNAL_DEPLOY_SECRET protects
# POST /api/internal/deploy-memecoin from the public internet.
# -----------------------------------------------------------------------------
# TRIGGER_HMAC_SECRET=
# DEPLOY_AGENT_URL=http://127.0.0.1:4077
# INTERNAL_DEPLOY_SECRET=

# -----------------------------------------------------------------------------
# Optional
# -----------------------------------------------------------------------------

# Moralis — Solana token data (same key for all Moralis routes)
# Used by: src/app/api/agent/moralis/route.ts (OHLCV for AI context)
#          src/app/api/token/metrics/route.ts (live MC for chart when bonded; fallback if curve MC missing)
# Get a key: https://admin.moralis.io/
MORALIS_API_KEY=

# Public Solana RPC URL for @solana/web3.js + pump SDK (browser)
# Used by: src/app/eve/page.tsx
# If unset, defaults to https://api.mainnet-beta.solana.com
# For heavier use, use a provider (Helius, Alchemy, QuickNode, etc.)
NEXT_PUBLIC_RPC_URL=

# -----------------------------------------------------------------------------
# /eve VPS stream (browser RTMP capture)
#
# Prefer EVE_* for production: read at runtime (force-dynamic /eve). Set in
# /etc/eve-core/app.env and restart eve-core — no rebuild.
# NEXT_PUBLIC_* still work as fallbacks; changing them needs npm run build.
# -----------------------------------------------------------------------------

# Default pump room: mint or full https://pump.fun/coin/... URL
# EVE_DEFAULT_ROOM=
# NEXT_PUBLIC_EVE_DEFAULT_ROOM=

# 1 = connect chat on load (pair with Chromium --autoplay-policy=no-user-gesture-required)
# EVE_AUTO_CONNECT=1
# NEXT_PUBLIC_EVE_AUTO_CONNECT=

# Display name for /api/pumpchat (empty → Anonymous AI Developer)
# EVE_STREAM_USERNAME=
# NEXT_PUBLIC_EVE_STREAM_USERNAME=

# Token name + ticker shown on the stream overlay (optional)
# EVE_STREAM_NAME=
# EVE_STREAM_TICKER=
# NEXT_PUBLIC_EVE_STREAM_NAME=
# NEXT_PUBLIC_EVE_STREAM_TICKER=

# 1 = hide token URL row on /eve (cleaner RTMP frame)
# EVE_KIOSK=1
# NEXT_PUBLIC_EVE_KIOSK=

# -----------------------------------------------------------------------------
# Tooling (usually unnecessary — npm scripts already set this)
# -----------------------------------------------------------------------------
# Force Next.js to use WASM SWC instead of native binaries (avoids bus errors
# on some Linux setups). The `dev` and `build` scripts in package.json set this.
# NEXT_TEST_WASM=1

# -----------------------------------------------------------------------------
# Troubleshooting: blank /eve, chat broken, console 404 on _next/static/chunks/main-app.js
# -----------------------------------------------------------------------------
# That URL is used in dev; production uses hashed names (main-app-<hash>.js). A 404 usually
# means the browser kept an old HTML snapshot while you switched modes or rebuilt.
#
# Fix: 1) Stop every Node process on port 3000 (or your port). 2) npm run clean
# 3) Either ONLY `npm run dev` OR `npm run build && npm start` — do not mix. 4) Hard refresh
# /eve (Cmd+Shift+R) or use a private window. 5) First dev load may compile ~10s; wait, then refresh.

# -----------------------------------------------------------------------------
# Ops dashboard (/ops) — Privy (Solana) + allowlisted wallets
# -----------------------------------------------------------------------------
# NEXT_PUBLIC_PRIVY_APP_ID=
# PRIVY_APP_SECRET=
# PRIVY_JWT_VERIFICATION_KEY=   # Privy dashboard → Verification key (PEM). One line in .env: use \n between PEM lines
# OPS_ADMIN_SOLANA_WALLETS=     # base58 addresses, comma-separated
# OPS_SESSION_SECRET=           # 16+ random chars (httpOnly cookie HMAC)
# DATABASE_URL=                 # optional Postgres for eve_ops_streams persistence
